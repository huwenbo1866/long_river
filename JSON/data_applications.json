                "params": [
                  "True",
                  "False"
                ]
              },
              {
                "setting": "batch_size",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "batch的大小，默认为64，建议根据实际配置进行调整"
              },
              {
                "setting": "shuffle_buffer_size",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "当该参数存在时，会调用dataset中的shuffle方法，默认为50000"
              },
              {
                "setting": "take_size",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "当该参数存在时，会调用dataset中的skip方法，创建一个测试数据集，默认不调用该参数。如果已经存在测试数据集，则该数据集无效。"
              }
            ],
            "setparams": {}
