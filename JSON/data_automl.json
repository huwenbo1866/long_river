        "params": [
          {
            "name": "images_dir",
            "pipelineIndex": "1",
            "type": "Module",
            "fun": "images_dir",
            "description": "使用tensorflow中的dataset模块从图片文件夹中读取数据，并创建数据集，效率较高",
            "params": [
              {
                "setting": "path",
                "required": "yes",
                "type": "UserFolderPath",
                "description": "用户传入的图片文件夹路径，该模块调用tensorflow中的dataset模块进行数据集的创建，默认路径下的子文件夹会被当做图片的各个类别"
              },
              {
                "setting": "hasTest",
                "description": "是否存在测试数据集，如果该参数存在，则从用户路径下的train，test两个文件夹分别创建两个数据集",
                "required": "yes",
                "type": "MultipleChoice",
                "params": [
                  "True",
                  "False"
                ]
              },
              {
                "setting": "shuffle_buffer_size",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "当该参数存在时，会调用dataset中的shuffle方法，默认为3000"
              },
              {
                "required": "yes",
                "setting": "img_height",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "对读取的图片进行大小变化，height为转换后的高度,默认为224"
              },
              {
                "required": "yes",
                "setting": "img_width",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "对读取的图片进行大小变化，height为转换后的宽度，默认为224"
              },
              {
                "required": "yes",
                "setting": "batch_size",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "dataset自带的batch_size函数，默认为64，建议根据实际配置进行调整"
              },
              {
                "setting": "take_size",
                "type": "int",
                "limit": "PositiveInteger",
                "description": "当该参数存在时，会调用dataset中的skip方法，创建一个测试数据集，默认不调用该参数。如果已经存在测试数据集，则该数据集无效。"
              }
