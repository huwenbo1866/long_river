[
  {
    "external_name": "数据读取",
    "description": "数据读取有关内容",
    "type": "Module",
    "parameter": [
      {
        "external_name": "数据读取器",
        "type": "Object",
        "description": "根据输入路径，生成对应的训练或评估数据的数据读取器。",
        "internal_name": "data_loader",
        "connection": {
          "index": "1",
          "following": [
            "0"
          ],
          "followers": [
            "2"
          ],
          "parameter": [
            {
              "external_name": "训练数据路径",
              "internal_name": "train_loader_path",
              "type": "hyperparameter",
              "description": "评估数据读取器的数据加载路径。如果为None，则不启用该数据读取器，在没有训练数据读取器的情况下，生成代码必然运行失败。默认值：None。",
              "class_name": [
                "user_filepath"
              ],
              "default": "object:None",
              "conditions": [
                "str"
              ]
            },
            {
              "external_name": "训练数据批处理大小（batch_size）",
              "internal_name": "train_loader_batch_size",
              "type": "hyperparameter",
              "description": "train_data和eval_data的批处理大小。当train_data和eval_data都是Dataloader的实例时，此参数将被忽略。",
              "class_name": [
                "int"
              ],
              "default": "int:10",
              "conditions": [
                "positive-integer"
              ]
            },
            {
              "external_name": "是否打乱训练数据(shuffle)",
              "internal_name": "train_loader_shuffle",
              "type": "hyperparameter",
              "description": "训练时随机打乱数据顺序。默认值：True。",
              "input_type": [
                "bool"
              ],
              "default": "bool:True"
            },
            {
              "external_name": "评估数据路径",
              "internal_name": "val_loader_path",
              "type": "hyperparameter",
              "description": "评估数据读取器的数据加载路径。如果为None，则不启用该数据读取器。默认值：None。",
              "class_name": [
                "user_filepath"
              ],
              "default": "object:None",
              "conditions": [
                "str"
              ]
            },
            {
              "external_name": "评估数据批处理大小（batch_size）",
              "internal_name": "val_loader_batch_size",
              "type": "hyperparameter",
              "description": "eval_data的批处理大小。当train_data和eval_data都是Dataloader的实例时，此参数将被忽略。",
              "class_name": [
                "int"
              ],
              "default": "int:10",
              "conditions": [
                "positive-integer"
              ]
            },
            {
              "external_name": "是否打乱评估数据(shuffle)",
              "internal_name": "val_loader_shuffle",
              "type": "hyperparameter",
              "description": "评估时随机打乱数据顺序。默认值：True。",
              "input_type": [
                "bool"
              ],
              "default": "bool:True"
            }
          ]
        }
      }
    ]
  },
  {
    "external_name": "转换层",
    "description": "包含可以用于进行数据转换的函数",
    "type": "Module",
    "parameter": [
      {
        "external_name": "尺寸调整",
        "type": "Object",
        "description": "将输入数据调整为指定大小。",
        "internal_name": "Resize",
        "connection": {
          "index": "2",
          "following": [
            "1"
          ],
          "followers": [
            "3"
          ]
        },
        "parameter": [
          {
            "external_name": "输出尺寸",
            "internal_name": "size",
            "type": "hyperparameter",
            "description": "(int|list|tuple) - 输出图像大小。如果size是一个序列，例如（h，w），输出大小将与此匹配。如果size为int，图像的较小边缘将与此数字匹配，即如果 height > width，则图像将重新缩放为(size * height / width, size)。",
            "input_type": [
              "int",
              "tuple",
              "list"
            ],
            "default": ""
          },
          {
            "external_name": "插值方法",
            "internal_name": "interpolation",
            "type": "hyperparameter",
            "description": "插值的方法. 默认值: 'bilinear'. 当使用 pil 作为后端时, 支持的插值方法如下: - \"nearest\": Image.NEAREST, - \"bilinear\": Image.BILINEAR, - \"bicubic\": Image.BICUBIC, - \"box\": Image.BOX, - \"lanczos\": Image.LANCZOS, - \"hamming\": Image.HAMMING；当使用 cv2 作为后端时, 支持的插值方法如下: - \"nearest\": cv2.INTER_NEAREST, - \"bilinear\": cv2.INTER_LINEAR, - \"area\": cv2.INTER_AREA, - \"bicubic\": cv2.INTER_CUBIC, - \"lanczos\": cv2.INTER_LANCZOS4",
            "input_type": [
              "str"
            ],
            "values": [
              "bilinear",
              "nearest",
              "bicubic",
              "box",
              "lanczos",
              "hamming",
              "nearest",
              "area"
            ],
            "default": "str:bilinear"
          }
        ]
      },
      {
        "external_name": "转换为张量",
        "type": "Object",
        "description": "将 PIL.Image 或 numpy.ndarray 转换成 paddle.Tensor。",
        "internal_name": "ToTensor",
        "connection": {
          "index": "2",
          "following": [
            "1"
          ],
          "followers": [
            "3"
          ]
        },
        "parameter": [
          {
            "external_name": "格式化方法",
            "internal_name": "data_format",
            "type": "hyperparameter",
            "description": "返回张量的格式，必须为 'HWC' 或 'CHW'。 默认值: 'CHW'。",
            "input_type": [
              "str"
            ],
            "default": "str:CHW"
          }
        ]
      },
      {
        "external_name": "图像归一化处理",
        "type": "Object",
        "description": "图像归一化处理，支持两种方式： 1. 用统一的均值和标准差值对图像的每个通道进行归一化处理； 2. 对每个通道指定不同的均值和标准差值进行归一化处理。",
        "internal_name": "Normalize",
        "connection": {
          "index": "2",
          "following": [
            "1"
          ],
          "followers": [
            "3"
          ]
        },
        "parameter": [
          {
            "external_name": "均值",
            "internal_name": "mean",
            "type": "hyperparameter",
            "description": "用于每个通道归一化的均值。",
            "input_type": [
              "int",
              "list"
            ],
            "default": "int:0"
          },
          {
            "external_name": "标准差值",
            "internal_name": "std",
            "type": "hyperparameter",
            "description": "用于每个通道归一化的标准差值。",
            "input_type": [
              "int",
              "list"
            ],
            "default": "int:1"
          },
          {
            "external_name": "是否转化为RGB格式",
            "internal_name": "to_rgb",
            "type": "hyperparameter",
            "description": "是否转换为 rgb 的格式。默认值：False。",
            "input_type": [
              "boolean"
            ],
            "default": "boolean:False"
          }
        ]
      }
    ]
  },
  {
    "external_name": "神经元",
    "description": "包含用于构建神经网络的神经元",
    "type": "Module",
    "parameter": [
      {
        "external_name": "一般神经元",
        "description": "非特殊类型的神经元的集合，包含线性神经元，平铺等等",
        "type": "Module",
        "internal_name": "nn",
        "parameter": [
          {
            "external_name": "线性神经元",
            "type": "Object",
            "description": "线性神经元，对应函数为paddle.nn.Linear。",
            "internal_name": "Linear",
            "connection": {
              "index": "3",
              "following": [
                "2",
                "3"
              ],
              "followers": [
                "3",
                "4"
              ]
            },
            "parameter": [
              {
                "external_name": "输入大小",
                "internal_name": "in_features",
                "type": "hyperparameter",
                "description": "线性变换层输入单元的数目。",
                "input_type": [
                  "int"
                ],
                "default": ""
              },
              {
                "external_name": "输出大小",
                "internal_name": "out_features",
                "type": "hyperparameter",
                "description": "线性变换层输出单元的数目。",
                "input_type": [
                  "int"
                ],
                "default": ""
              },
              {
                "external_name": "输出大小",
                "internal_name": "weight_attr",
                "type": "hyperparameter",
                "description": "指定权重参数的属性。默认值为None，表示使用默认的权重参数属性，将权重参数初始化为0。",
                "input_type": [
                  "int"
                ],
                "default": "None"
              },
              {
                "external_name": "输出大小",
                "internal_name": "bias_attr",
                "type": "hyperparameter",
                "description": "指定偏置参数的属性。 bias_attr 为bool类型且设置为False时，表示不会为该层添加偏置。 bias_attr 如果设置为True或者None，则表示使用默认的偏置参数属性，将偏置参数初始化为0。具体用法请参见 ParamAttr 。默认值为None。",
                "input_type": [
                  "bool"
                ],
                "default": "object:None"
              }
            ]
          },
          {
            "external_name": "Flatten（展开）",
            "type": "Object",
            "description": "该接口用于构造一个 Flatten 类的可调用对象。更多信息请参见代码示例。它实现将一个连续维度的Tensor展平成一维Tensor。",
            "internal_name": "Flatten",
            "connection": {
              "index": "3",
              "following": [
                "2",
                "3"
              ],
              "followers": [
                "3",
                "4"
              ]
            },
            "parameter": [
              {
                "external_name": "起始维度",
                "internal_name": "start_axis",
                "type": "hyperparameter",
                "description": " 展开的起始维度，默认值为1。",
                "input_type": [
                  "int"
                ],
                "default": "1"
              },
              {
                "external_name": "结束维度",
                "internal_name": "stop_axis",
                "type": "hyperparameter",
                "description": "展开的结束维度，默认值为-1。。",
                "input_type": [
                  "int"
                ],
                "default": "-1"
              }
            ]
          }
        ]
      },
      {
        "external_name": "卷积神经元",
        "description": "机器学习常用的线性模型，主要以线性回归，Lasso回归，弹性网络等等为主",
        "type": "Module",
        "func": "linear_model",
        "parameter": [
          {
            "external_name": "二维卷积层",
            "type": "Object",
            "description": "二维卷积层（convolution2d layer），根据输入、卷积核、步长（stride）、填充（padding）、空洞大小（dilations）一组参数计算输出特征层大小。",
            "internal_name": "Conv2D",
            "connection": {
              "index": "3",
              "following": [
                "2",
                "3"
              ],
              "followers": [
                "3",
                "4"
              ]
            },
            "parameter": [
              {
                "external_name": "输入大小",
                "internal_name": "in_channels",
                "type": "hyperparameter",
                "description": "输入图像的通道数。",
                "input_type": [
                  "int"
                ],
                "default": ""
              },
              {
                "external_name": "输出大小",
                "internal_name": "out_channels",
                "type": "hyperparameter",
                "description": "由卷积操作产生的输出的通道数。",
                "input_type": [
                  "int"
                ],
                "default": ""
              },
              {
                "external_name": "卷积核大小",
                "internal_name": "kernel_size",
                "type": "hyperparameter",
                "description": "卷积核大小。可以为单个整数或包含两个整数的元组或列表，分别表示卷积核的高和宽。如果为单个整数，表示卷积核的高和宽都等于该整数。",
                "input_type": [
                  "int"
                ],
                "default": ""
              },
              {
                "external_name": "填充大小",
                "internal_name": "padding",
                "type": "hyperparameter",
                "description": "填充大小。如果它是一个字符串，可以是\"VALID\"或者\"SAME\"，表示填充算法。",
                "input_type": [
                  "single_choice"
                ],
                "values": [
                  "normal",
                  "uniform"
                ],
                "default": "0"
              },
              {
                "external_name": "步长大小",
                "internal_name": "stride",
                "type": "hyperparameter",
                "description": "步长大小。可以为单个整数或包含两个整数的元组或列表，分别表示卷积沿着高和宽的步长。如果为单个整数，表示沿着高和宽的步长都等于该整数。默认值：1。",
                "input_type": [
                  "int"
                ],
                "default": "1"
              },
              {
                "external_name": "输出大小",
                "internal_name": "dilation",
                "type": "hyperparameter",
                "description": "空洞大小。可以为单个整数或包含两个整数的元组或列表，分别表示卷积核中的元素沿着高和宽的空洞。如果为单个整数，表示高和宽的空洞都等于该整数。默认值：1。",
                "input_type": [
                  "int"
                ],
                "default": "1"
              }
            ]
          }
        ]
      },
      {
        "external_name": "池化神经元",
        "description": "机器学习常用的线性模型，主要以线性回归，Lasso回归，弹性网络等等为主",
        "type": "Module",
        "func": "linear_model",
        "parameter": [
        ]
      }
    ]
  },
  {
    "external_name": "模型处理",
    "description": "包含模型的准备、训练、评估、保存等动作。",
    "type": "Module",
    "internal_name": "model",
    "parameter": [
      {
        "external_name": "模型准备/编译（model.prepare）",
        "internal_name": "prepare",
        "description": "模型训练所需参数，包括优化器，损失函数和评估函数。代码为\"model.prepare()\"对应在TensorFlow中compile",
        "type": "Object",
        "connection": {
          "index": "4",
          "following": [
            "3"
          ],
          "followers": [
            "5"
          ]
        },
        "parameter": [
          {
            "external_name": "优化器",
            "internal_name": "optimizer",
            "type": "hyperparameter",
            "description": "必须在训练中设置优化器并且应该是Optimizer实例。",
            "class_name": [
              "single_choice_object"
            ],
            "values": [
              "Optimizer",
              "Adagrad",
              "Adam",
              "AdamW",
              "Adamax",
              "RMSProp",
              "Adadelta",
              "SGD",
              "Momentum",
              "Lamb",
              "lr"
            ],
            "default": "object:Adam"
          },
          {
            "external_name": "损失函数",
            "internal_name": "loss",
            "type": "hyperparameter",
            "description": "损失函数可以是`paddle.nn.Layer`实例或任何可调用函数。损失函数是模型训练是计算时模型计算损失的函数，如交叉熵损失等",
            "class_name": [
              "single_choice_object"
            ],
            "values": [
              "BCEWithLogitsLoss",
              "CrossEntropyLoss",
              "HSigmoidLoss",
              "MSELoss",
              "L1Loss",
              "NLLLoss",
              "BCELoss",
              "KLDivLoss",
              "MarginRankingLoss",
              "CTCLoss",
              "SmoothL1Loss"
            ],
            "default": "object:CrossEntropyLoss"
          },
          {
            "external_name": "评估函数",
            "internal_name": "metrics",
            "type": "hyperparameter",
            "description": "指标或者评价函数，其是用来评价模型训练效果的函数，如正确率，召回率等等",
            "class_name": [
              "single_choice_object"
            ],
            "values": [
              "Accuracy",
              "Precision",
              "Recall",
              "Auc",
              "accuracy"
            ],
            "default": "object:Accuracy"
          }
        ]
      },
      {
        "external_name": "模型训练（model.fit）",
        "description": "模型训练函数，代码为\"model.fit()\"。",
        "type": "Object",
        "internal_name": "fit",
        "connection": {
          "index": "5",
          "following": [
            "4"
          ],
          "followers": [
            "6"
          ]
        },
        "parameter": [
          {
            "external_name": "批处理大小（batch_size）",
            "internal_name": "batch_size",
            "type": "hyperparameter",
            "description": "train_data和eval_data的批处理大小。当train_data和eval_data都是Dataloader的实例时，此参数将被忽略。",
            "class_name": [
              "int"
            ],
            "default": "int:1",
            "conditions": [
              "positive-integer"
            ]
          },
          {
            "external_name": "训练次数（epochs）",
            "internal_name": "epochs",
            "type": "hyperparameter",
            "description": "epochs，正整数，默认为1。当一个完整的数据集通过了神经网络一次并且返回了一次，这个过程称为一个 epoch。",
            "class_name": [
              "int"
            ],
            "default": "int:1",
            "conditions": [
              "positive-integer"
            ]
          },
          {
            "external_name": "保存路径（save_dir）",
            "internal_name": "save_dir",
            "type": "hyperparameter",
            "description": "训练期间保存检查点的目录。如果为None，将不保存检查点。默认值：None。",
            "class_name": [
              "user_filepath"
            ],
            "default": "object:None",
            "conditions": [
              "str"
            ]
          }
        ]
      },
      {
        "external_name": "模型评估（model.evaluate）",
        "description": "模型评估函数，代码为\"model.evaluate()\"。",
        "type": "Object",
        "internal_name": "evaluate",
        "connection": {
          "index": "6",
          "following": [
            "5"
          ],
          "followers": [
            "7"
          ]
        },
        "parameter": [
          {
            "external_name": "use_val_loader（bool）",
            "internal_name": "num_workers",
            "type": "hyperparameter",
            "description": "是否使用评估数据集，如果选False，则使用训练数据集进行评估。默认值：True",
            "class_name": [
              "bool"
            ],
            "default": "bool:True"
          },
          {
            "external_name": "num_workers（int）",
            "internal_name": "num_workers",
            "type": "hyperparameter",
            "description": "加载数据的子进程的数量，如果不使用任何子进程并在主进程中加载数据，则为0。当train_data和eval_data都是Dataloader的实例时，此参数将被忽略。默认值：0",
            "class_name": [
              "int"
            ],
            "default": "int:0",
            "conditions": [
              "non-negative-integer"
            ]
          }
        ]
      },
      {
        "external_name": "模型保存（model.save）",
        "description": "模型保存函数，代码为\"model.save()\"。",
        "type": "Object",
        "internal_name": "fit",
        "connection": {
          "index": "5",
          "following": [
            "4"
          ],
          "followers": [
            "6"
          ]
        },
        "parameter": [
          {
            "external_name": "保存路径（path (str)）",
            "internal_name": "path",
            "type": "hyperparameter",
            "description": "保存的文件名前缀。格式如 dirname/file_prefix 或者 file_prefix。默认值：checkpoint/test。",
            "class_name": [
              "user_filepath"
            ],
            "default": "str:checkpoint/test",
            "conditions": [
              "str"
            ]
          },
          {
            "external_name": "training (bool，可选)",
            "internal_name": "training",
            "type": "hyperparameter",
            "description": "是否保存训练的状态，包括模型参数和优化器参数等。如果为False，则只保存推理所需的参数与文件。默认值：True。",
            "input_type": [
              "bool"
            ],
            "default": "bool:True"
          }
        ]
      }
    ]
  }
]